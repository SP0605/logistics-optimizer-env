# This file is used to store environment variables for local development.
# On Hugging Face Spaces, these should be set as secrets.

# The base URL of your running FastAPI application
API_BASE_URL="http://127.0.0.1:8000"

# The model identifier for the LLM you want to use
MODEL_NAME="gpt-3.5-turbo"

# Your Hugging Face token or API key for the LLM provider
# For OpenAI-compatible endpoints, this is usually the API key.
HF_TOKEN="your-api-key-here"
OPENAI_API_BASE_URL="https://api.openai.com/v1" # Or your custom HF inference endpoint
